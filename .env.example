# Example Environment Configuration
# Copy this file to .env and fill with your actual values
# DO NOT commit .env to version control

# ── GitHub Copilot (obrigatório) ────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelos por tier (defaults já corretos no settings.py)
DEFAULT_MODEL=claude-sonnet-4-6
TIER_MODEL_MAP={"T1":"claude-sonnet-4-6","T2":"gpt-4.1","T3":"gpt-4.1-mini"}
TIER_TURNS_MAP={"T1":20,"T2":12,"T3":5}

# ── Databricks (opcional) ──────────────────────────────────────────────────
# Auth opção 1: Personal Access Token
DATABRICKS_HOST=https://workspace-name.cloud.databricks.com
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth opção 2: OAuth M2M (Service Principal) — alternativa ao token
# DATABRICKS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# DATABRICKS_CLIENT_SECRET=xxxxxxxx
# Auth opção 3: Extensão Databricks VS Code — não precisa configurar nada aqui
DATABRICKS_SQL_WAREHOUSE_ID=xxxxxxxxxxxxxxxx
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default

# ── Microsoft Fabric (opcional) ────────────────────────────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxx
FABRIC_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── QA Orchestrator ─────────────────────────────────────────────────────────
QA_ENABLED=true
QA_MAX_ROUNDS=3
QA_SCORE_THRESHOLD=0.7

# ── Operacional ─────────────────────────────────────────────────────────────
MAX_BUDGET_TOKENS=500000
CONSOLE_LOG_LEVEL=WARNING
OUTPUT_MAX_CHARS=8000
SESSION_MAX_RESUME_TURNS=10

# ── GitHub PAT (opcional, para integração com fabric-ci-cd) ────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
