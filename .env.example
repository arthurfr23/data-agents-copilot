# ─── GitHub Copilot ─────────────────────────────────────────────────────────
# Token OAuth do GitHub. Gerado em: Settings > Developer Settings > Personal Access Tokens
# Scopes necessários: copilot (ou GitHub Copilot API access via organização)
GITHUB_TOKEN=github_pat_...

# Modelo padrão do Supervisor. Modelos disponíveis no Copilot:
#   claude-sonnet-4-5 | claude-opus-4-5 | gpt-4o | gpt-4o-mini | o3-mini
DEFAULT_MODEL=claude-sonnet-4-5

# Mapeamento de modelos por tier (JSON). Sobrescreve frontmatter dos agentes.
TIER_MODEL_MAP={"T1": "claude-sonnet-4-5", "T2": "gpt-4o", "T3": "gpt-4o-mini"}

# Limite de turns por tier
TIER_TURNS_MAP={"T1": 20, "T2": 12, "T3": 5}

# ─── Databricks ──────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXX.XX.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXX
DATABRICKS_SQL_WAREHOUSE_ID=XXXXXXXXXXXXXXXX
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default

# ─── Microsoft Fabric ────────────────────────────────────────────────────────
AZURE_TENANT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_CLIENT_SECRET=XXXX
FABRIC_WORKSPACE_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ─── GitHub (para MCP) ───────────────────────────────────────────────────────
# Pode reutilizar o mesmo GITHUB_TOKEN acima se tiver os scopes repo, read:org
# GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...

# ─── Controles de sessão ─────────────────────────────────────────────────────
MAX_TURNS=50
MAX_BUDGET_TOKENS=500000
AGENT_PERMISSION_MODE=bypassPermissions
CONSOLE_LOG_LEVEL=WARNING
MEMORY_ENABLED=true
